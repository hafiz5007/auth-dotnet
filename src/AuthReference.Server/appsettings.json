{
  "AuthReference": {
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=auth_reference;Username=auth_ref;Password=auth_ref_dev_password",
      "CommandTimeoutSeconds": 30
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "KeyPrefix": "auth-ref:",
      "TokenVersionTtlSeconds": 60
    },
    "Jwt": {
      "Issuer": "https://auth-reference.local/",
      "Audience": "auth-reference-api",
      "SigningKey": "REPLACE-WITH-32-BYTE-SECRET-FROM-KEY-VAULT-IN-PRODUCTION!!",
      "AccessTokenLifetimeMinutes": 10,
      "RefreshTokenLifetimeDays": 14
    },
    "Password": {
      "Pbkdf2Iterations": 600000
    },
    "Retention": {
      "SweepInterval": "24:00:00",
      "RefreshTokenGrace": "7.00:00:00",
      "AuditRetention": "180.00:00:00"
    },
    "OpenIddict": {
      "Spa": {
        "ClientId": "spa-client",
        "DisplayName": "SPA Client (Auth Code + PKCE)",
        "RedirectUris": [ "http://localhost:3000/callback" ],
        "PostLogoutRedirectUris": [ "http://localhost:3000/" ]
      },
      "Worker": {
        "ClientId": "backend-worker",
        "ClientSecret": "worker-secret-replace-in-prod",
        "DisplayName": "Backend Worker (Client Credentials)"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "OpenIddict": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://+:5001" }
    }
  }
}
